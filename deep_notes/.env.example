# === API ===
API_KEY=change-me-to-a-secret

# === Vault ===
VAULT_PATH=/path/to/your/obsidian/vault

# === Embedding ===
EMBED_PROVIDER=ollama          # ollama | openai
EMBED_MODEL=bge-m3
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...        # only needed if EMBED_PROVIDER=openai

# === Vector Store ===
VECTOR_STORE_PROVIDER=qdrant   # qdrant | chroma
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=obsidian_notes

# === Chunking ===
CHUNK_STRATEGY=sentence        # sentence | token | markdown
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# === LLM ===
LLM_PROVIDER=openrouter        # openrouter | openai | ollama
LLM_MODEL=anthropic/claude-sonnet-4
OPENROUTER_API_KEY=sk-or-...

# === Retrieval ===
SIMILARITY_TOP_K=5
